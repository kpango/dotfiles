local name="$1"
local defer=$2
local cmd="$3"
local cache_file="$ZCACHE_DIR/${name}.zsh"
shift 3

# defer=-1: force regenerate + synchronous zcompile + no source (used by zprecompile)
local need_eval=0
if (( defer == -1 )) || [[ ! -f "$cache_file" ]]; then
	need_eval=1
else
	for d in "$@"; do
		if [[ -n "$d" && "$d" -nt "$cache_file" ]]; then
			need_eval=1
			break
		fi
	done
fi

if (( need_eval )); then
	local stale=(${cache_file}.lock(Nms+30))
	if (( ${#stale} > 0 )); then
		command rmdir "${cache_file}.lock" 2>/dev/null
	fi

	if command mkdir "${cache_file}.lock" 2>/dev/null; then
		eval "$cmd" > "${cache_file}.tmp"
		command mv -f "${cache_file}.tmp" "$cache_file"
		command rmdir "${cache_file}.lock" 2>/dev/null
		if (( defer == -1 )); then
			zcompile "$cache_file" 2>/dev/null
		else
			zcompile "$cache_file" 2>/dev/null &|
		fi
	else
		local i=0
		while [[ -d "${cache_file}.lock" ]] && (( i < 1200 )); do
			builtin read -t 0.05 </dev/null 2>/dev/null || sleep 0.05 2>/dev/null
			(( i++ ))
		done
		if [[ ! -f "$cache_file" ]]; then
			eval "$cmd" > "${cache_file}.tmp.$$"
			command mv -f "${cache_file}.tmp.$$" "$cache_file"
		fi
	fi
fi

(( defer == -1 )) && return

if (( defer )) && (($+functions[zsh-defer])); then
	zsh-defer source "$cache_file"
else
	source "$cache_file"
fi