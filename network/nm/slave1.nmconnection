[connection]
id=slave1
uuid=7773eaaf-9f6f-4cb1-8337-ca6c07aa86af
type=ethernet
controller=bond0
interface-name=sfp1
port-type=bond

[ethernet]
auto-negotiate=true

[802-3-ethernet]
mac-address=64:9D:99:B1:03:45
duplex=full

[bond-port]

[ethtool]
feature-hw-tc-offload=true
feature-tx-tcp-segmentation=true
feature-tx-tcp6-segmentation=true
feature-rx-gro-list=true
feature-rx-udp-gro-forwarding=true
ring-rx=8160
ring-tx=8160
pause-rx=true
pause-tx=true
