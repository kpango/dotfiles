[connection]
id=slave1
uuid=2780dc6e-e321-40e6-9e26-6988aa71525a
type=ethernet
controller=bond0
interface-name=sfp1
port-type=bond
timestamp=1738635599

[ethernet]
auto-negotiate=true

[802-3-ethernet]
mac-address=64:9D:99:B1:03:45
duplex=full
mtu=9000

[bond-port]

[ethtool]
# offload settings (basic offload features are on by default for i40e)
feature-tx-tcp-segmentation=true
feature-tx-tcp6-segmentation=true
feature-rx-gro-list=true
feature-rx-udp-gro-forwarding=true

# ring buffer size (max 8160 for i40e)
ring-rx=8160
ring-tx=8160

# flow control
pause-rx=true
pause-tx=true
