{
  "layer": "top",
  "output": ["eDP-1", "DP-1", "DP-2", "DP-3", "DP-4", "HDMI-A-1"],
  "position": "top",
  "height": 34,
  "spacing": 2,
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["sway/window"],
  "modules-right": [
    "pulseaudio",
    "network",
    "cpu",
    "temperature",
    "memory",
    "disk",
    "custom/ssd",
    "backlight",
    "battery",
    "custom/powerbar",
    "clock",
    "tray"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "яДЬ {}"
  },
  "sway/window": {
    "format": "{}",
    "max-length": 60
  },
  "tray": {
    "spacing": 6,
    "icon-size": 16
  },
  "clock": {
    "interval": 1,
    "format": "яАЧ {:%H:%M:%S}",
    "format-alt": "яАЧ  {:%Y-%m-%d (%a) %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#cba6f7'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks": "<span color='#a6e3a1'><b>W{}</b></span>",
        "weekdays": "<span color='#89b4fa'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "interval": 2,
    "format": "яТ╝ {usage}%",
    "tooltip": false,
    "on-click": "ghostty -e btop"
  },
  "memory": {
    "interval": 2,
    "format": "ю┐Е {used:.1f}G",
    "tooltip-format": "{used:.1f}G / {total:.1f}G used\n{available:.1f}G available",
    "on-click": "ghostty -e btop"
  },
  "temperature": {
    "interval": 5,
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["яЛЛ", "яЛИ", "яЛЙ", "яЛЙ", "яЛЗ"]
  },
  "backlight": {
    "interval": 30,
    "format": "яЖЕ {percent}%",
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    "on-scroll-up": "brightnessctl -c backlight set +5%"
  },
  "battery": {
    "bat": "BAT0",
    "interval": 30,
    "states": {
      "good": 90,
      "warning": 30,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яН╢ {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "custom/powerbar": {
    "return-type": "json",
    "interval": 1,
    "exec": "$HOME/.config/waybar/powerbar -full 'FULL - {usage}W' -charging '{state} {capacity}% - {usage}W - {H}h {M}m' -waybar 2> /dev/null"
  },
  "disk": {
    "interval": 30,
    "format": "яВа {used}/{total}",
    "path": "/"
  },
  "network": {
    "format": "тЪа Disabled",
    "format-wifi": "яЗл {essid} {signalStrength}%",
    "format-ethernet": "яГи {ipaddr}/{cidr}",
    "format-linked": "яГи {ifname} (No IP)",
    "format-disconnected": "тЪа Disconnected",
    "format-alt": "яГи {ifname}: {ipaddr}/{cidr}  тЖС{bandwidthUpBits} тЖУ{bandwidthDownBits}",
    "tooltip-format": "{ifname}: {ipaddr}\n{gwaddr} via {ifname}",
    "on-click": "ghostty -e nmtui"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "яКФ {icon} {volume}%",
    "format-bluetooth-muted": "яКФ яАж",
    "format-muted": "яАж",
    "format-source": "яД░ {volume}%",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яАе",
      "headset": "яАе",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol",
    "tooltip-format": "{desc}"
  },
  "bluetooth": {
    "format": "яКФ {status}",
    "format-connected": "яКФ {device_alias}",
    "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "bluetoothctl power on",
    "on-click-right": "bluetoothctl power off"
  },
  "custom/ssd": {
    "format": "яЛЙ {}┬░C",
    "exec": "sudo nvme --smart-log /dev/nvme0 | grep temperature | awk '{print $3}'",
    "interval": 30,
    "on-click": "ghostty -e watch sensors"
  }
}
